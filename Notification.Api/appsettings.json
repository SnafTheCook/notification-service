{
  "NotificationSettings": {
    "Channels": [
      {
        "Type": "Sms",
        "Providers": [
          {
            "Name": "Twilio",
            "Priority": 1,
            "IsEnabled": true
          },
          {
            "Name": "Vonage",
            "Priority": 2,
            "IsEnabled": true
          }
        ]
      },
      {
        "Type": "Email",
        "Providers": [
          {
            "Name": "AmazonSNS",
            "Priority": 1,
            "IsEnabled": true
          }
        ]
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=notifications.db"
  },
  "AllowedHosts": "*"
}
